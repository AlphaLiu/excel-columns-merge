{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Excel列提取合并器",
  "version": "0.1.0",
  "identifier": "com.tauri.excel-columns-merge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/dev-tauri.js",
    "beforeBuildCommand": "node scripts/build-tauri.js"
  },
  "app": {
    "windows": [
      {
        "title": "Excel列提取合并器",
        "width": 1080,
        "height": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "template": "bundle-scripts/windows/nsis/x64/installer.nsi",
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
